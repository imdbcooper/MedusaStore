# ============================================
# Docker Compose Environment Variables (ШАБЛОН)
# Clean-clone canonical flow:
#   cp .env.example .env
#   npm run bootstrap
#   npm run preflight
#   npm run dev
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=slavx
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=medusa
POSTGRES_PORT=5433

# --- Local ports ---
REDIS_PORT=6379
MEDUSA_BACKEND_PORT=9000
STOREFRONT_PORT=8000

# --- Local user mapping for generated files ---
HOST_UID=1000
HOST_GID=1000

# --- Внутренние ссылки (Docker-сеть) ---
DATABASE_URL=postgresql://slavx:CHANGE_ME@medusa-db:5432/medusa
REDIS_URL=redis://medusa-redis:6379

# --- Medusa ---
NODE_ENV=development
JWT_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME

# --- CORS ---
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
