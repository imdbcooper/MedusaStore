# ============================================
# Docker Compose Environment Variables (TEMPLATE-SAFE BASELINE)
# Canonical client-init contract:
#   npm run client:init:contract
# Clean-clone canonical flow:
#   cp .env.example .env
#   npm run bootstrap
#   npm run preflight
#   npm run dev
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=medusa
POSTGRES_PORT=5433

# --- Local ports ---
REDIS_PORT=6379
MEDUSA_BACKEND_PORT=9000
MEDUSA_ADMIN_HMR_PORT=5173
STOREFRONT_PORT=8000
PAYLOAD_PORT=3100
STOREFRONT_URL=http://localhost:8000

# --- Email verification (customer signup) ---
# TTL of the issued email verification token in minutes; default 1440 (24h).
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# Optional redirect path override inside the storefront verify link; default /account/verify-email.
EMAIL_VERIFICATION_REDIRECT_PATH=/account/verify-email

# --- Password reset (customer forgot/reset) ---
# TTL of the issued password reset token in minutes; default 60 (shorter than email verification
# because it is security-sensitive).
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Optional redirect path override inside the storefront reset link; default /account/reset-password.
PASSWORD_RESET_REDIRECT_PATH=/account/reset-password
# Minimum password length; absolute floor is 8. Applies to reset and authenticated change.
PASSWORD_MIN_LENGTH=8
# Require at least one letter (true|false); default true.
PASSWORD_REQUIRE_LETTER=true
# Require at least one digit (true|false); default true.
PASSWORD_REQUIRE_DIGIT=true

# --- Local user mapping for generated files ---
HOST_UID=1000
HOST_GID=1000

# --- Внутренние ссылки (Docker-сеть) ---
DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@medusa-db:5432/medusa
REDIS_URL=redis://medusa-redis:6379

# --- Medusa ---
NODE_ENV=development
JWT_SECRET=CHANGE_ME_JWT_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET
NOTIFICATION_EMAIL_PROVIDER=local
NOTIFICATION_EMAIL_FROM=notifications@example.com
# Optional backend-only UniSender credentials for production email path.
UNISENDER_API_KEY=
UNISENDER_BASE_URL=
# Optional backend-only SMTP transport. Keep provider=local until SMTP secrets/TLS/PTR are ready.
# Example future activation for current mail VPS: provider=smtp, host=smtp.slavx.ru, port=587, from=noreply@notify.slavx.ru.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_REPLY_TO=
# Bootstrap/self-signed only. Do not set false for final production with a trusted cert.
SMTP_TLS_REJECT_UNAUTHORIZED=true
# --- Email brand theming (transactional HTML templates) ---
# All BRAND_* vars are optional; safe defaults are used when empty.
BRAND_NAME=SLAVX Studio
# Optional absolute URL to the brand logo shown in the email header.
BRAND_LOGO_URL=
# Hex colors used by the branded email template. Defaults are safe for light inbox backgrounds.
BRAND_PRIMARY_COLOR=#111827
BRAND_ACCENT_COLOR=#10b981
BRAND_TEXT_COLOR=#111827
BRAND_BACKGROUND_COLOR=#f9fafb
# Optional legal/contact HTML footer appended under each email (no <script>/<style>/<iframe>/on*=).
BRAND_FOOTER_HTML=
# --- Marketing (Phase 4 groundwork) ---
# Optional separate marketing sender. Falls back to SMTP_FROM/NOTIFICATION_EMAIL_FROM when empty.
# Groundwork only: production-grade separation requires a dedicated SMTP account on the mail server.
MARKETING_EMAIL_FROM=
MARKETING_EMAIL_FROM_NAME=
MARKETING_EMAIL_REPLY_TO=
# Optional mailto address used in the List-Unsubscribe header for marketing emails.
# Leave empty to emit only the https URL part. When set, the value MUST resolve to a
# real inbox on the outbound mail server, otherwise Gmail/Yahoo may treat the header
# as broken and lower deliverability.
MARKETING_UNSUBSCRIBE_MAILTO=
# TTL for double opt-in confirmation tokens (days). Links are rotated on re-subscribe.
MARKETING_DOUBLE_OPTIN_TOKEN_TTL_DAYS=7
# TTL for unsubscribe tokens (days). Industry convention is long-lived; 365 is the recommended default.
MARKETING_UNSUBSCRIBE_TOKEN_TTL_DAYS=365
# Storefront paths for marketing confirm and unsubscribe landing pages.
MARKETING_UNSUBSCRIBE_REDIRECT_PATH=/unsubscribe
MARKETING_CONFIRMATION_REDIRECT_PATH=/marketing/confirm
# Default country code injected into storefront marketing URLs (`/{code}/...`).
# Customers can override via `customer.metadata.marketing.preferred_country_code`.
MARKETING_DEFAULT_COUNTRY_CODE=ru
# Default country code injected into storefront transactional URLs
# (email verification, password reset, marketing confirmation).
# Falls back to `ru` when this env is unset and the caller omits country_code.
NOTIFICATION_DEFAULT_COUNTRY_CODE=ru
# Optional backend-only SMS transport contract.
NOTIFICATION_SMS_PROVIDER=disabled
MTS_EXOLVE_API_KEY=
MTS_EXOLVE_SENDER=
MTS_EXOLVE_BASE_URL=
# Optional backend-only VK Community Messaging transport contract.
NOTIFICATION_VK_PROVIDER=disabled
VK_COMMUNITY_ACCESS_TOKEN=
VK_COMMUNITY_GROUP_ID=
VK_API_VERSION=
# Optional backend-only VK ID identity-linking contract.
VK_ID_ENABLED=false
# Phase 5.1: gate the public VK ID login flow independently from the linking
# surface so login can be activated only after the linked customer flow has
# been smoke-tested. Default false keeps Phase 5.1 disabled until staging is
# explicitly opted in.
VK_ID_LOGIN_ENABLED=false
# Phase 5.2: gate the VK ID registration branch. When true AND VK_ID_ENABLED
# AND VK_ID_LOGIN_ENABLED are all true, the callback will auto-create a
# customer if the VK identity is not yet linked and the VK email is unique.
# Leave false to keep Phase 5.1 login-only semantics.
VK_ID_REGISTER_ENABLED=false
# Phase 5.3: VK ID email trust policy. VK returns an email in the configured
# `vkid.personal_info + email` scope in practice; this flag controls what we
# do with it.
#   any                  (default, MVP): stamp `email_verified=true`, skip
#                        the transactional verification email. Trusts VK's
#                        email on face value.
#   require_verification: stamp `email_verified=false`, let the subscriber
#                        send the verification email like a regular emailpass
#                        registration. Use when raising the security bar for
#                        production.
#   reject               : disable VK-driven registration entirely. Callback
#                        surfaces `vk_login_error=email_trust_policy_reject`
#                        so the storefront can route the user to emailpass.
VK_ID_EMAIL_TRUST_POLICY=any
# Phase 5.3: TTL (minutes) for the signed pending-link token minted when the
# callback detects the email_exists conflict. The storefront conflict page
# must be submitted before this expires. 10 minutes is the default; clamp
# at 1 minute minimum.
VK_ID_PENDING_TOKEN_TTL_MINUTES=10
# DEPRECATED (Phase 5.3): VK_ID_REQUIRE_EMAIL is removed. Leaving it set is
# backward compatible — the runtime ignores the value. VK_ID_EMAIL_TRUST_POLICY
# replaces the one remaining use case (trusting VK's email without re-verify).
# VK_ID_REQUIRE_EMAIL=true
VK_ID_CLIENT_ID=
# Optional: VK ID OAuth 2.1 supports PKCE-only for public clients. Leave
# empty to use PKCE-only; set the confidential client secret to switch to
# the confidential flow if VK requires it.
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=
VK_ID_SCOPES=
VK_ID_SESSION_SECRET=
VK_ID_STOREFRONT_RETURN_ORIGINS=http://localhost:8000
# Controls the `Secure` flag on the `_medusa_jwt` cookie set by the VK ID
# login callback.
#   auto   (default): Secure is on when VK_ID_REDIRECT_URI uses https://,
#                     and off for plain http:// (local dev).
#   true             : always set Secure (use for https-behind-proxy setups
#                     where the backend sees http:// internally).
#   false            : never set Secure (local debugging only; do not use in
#                     staging or production).
VK_ID_COOKIE_SECURE=auto
# Optional local smoke helpers for authenticated admin notification requests
MEDUSA_BACKEND_URL=http://localhost:9000
NOTIFICATION_SMOKE_TO=ops@example.com
NOTIFICATION_SMOKE_SUBJECT=Notification v1 smoke
NOTIFICATION_SMOKE_MESSAGE=Notification v1 smoke trigger completed.
# Set true to validate admin smoke route authentication without creating a notification or sending email.
NOTIFICATION_SMOKE_DRY_RUN=false
# Optional staging-only override when verification must authenticate against an already-seeded non-local backend.
NOTIFICATION_SMOKE_ADMIN_SECRET_API_KEY=
# Optional explicit backend data-plane endpoints for fresh key creation during staging verification.
BACKEND_DATABASE_URL=
BACKEND_REDIS_URL=
# Optional contour override, for example smoke:backend,smoke:storefront,smoke:browser or smoke:backend,smoke:notification
STAGING_VERIFICATION_CONTOUR=smoke:backend,smoke:storefront,smoke:browser,smoke:notification
# Optional browser target path override for staging storefront verification.
STAGING_BROWSER_ACCOUNT_PATH=/ru/account
# ApiShip/Gorgo is the default fulfillment contour for fresh stores.
# Configure ApiShip token, sandbox/live mode, sender data, default dimensions,
# and carrier connections in Medusa Admin; do not commit real credentials to templates.
# Checkout may calculate rates and commit the selected ApiShip shipping method, but actual
# external fulfillment/shipment execution is default-off unless this exact opt-in is set to true.
APISHIP_SHIPMENT_EXECUTION_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
# Optional backend-controlled allowlist for storefront checkout return origins. Comma-separated origins only.
YOOKASSA_STOREFRONT_RETURN_ORIGINS=http://localhost:8000
# Public Medusa backend endpoint for YooKassa notifications, for example https://api.example.com/yookassa/webhook
YOOKASSA_WEBHOOK_URL=
# Optional shared secret expected in x-yookassa-webhook-secret, x-yookassa-secret, or Authorization: Bearer <secret>
YOOKASSA_WEBHOOK_SECRET=
# Development/test-only override for controlled local environments when YooKassa cannot send a secret header.
YOOKASSA_ALLOW_UNSIGNED_WEBHOOKS=false

# --- AI Assistant optional integration ---
# Server-side token stays only in backend/root env. Do not expose it via NEXT_PUBLIC_* variables.
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_BASE_URL=http://ai-assistant:8000/api/v1
AI_ASSISTANT_API_TOKEN=CHANGE_ME_AI_ASSISTANT_API_TOKEN
AI_ASSISTANT_SERVER_TOKEN=CHANGE_ME_AI_ASSISTANT_SERVER_TOKEN
AI_ASSISTANT_TIMEOUT_MS=60000
AI_ASSISTANT_CORS_ORIGINS=http://localhost:8000,http://localhost:5173
AI_ASSISTANT_RETRIEVAL_MODE=markdown
ASSISTANT_POSTGRES_URI=postgresql://assistant:CHANGE_ME_ASSISTANT_POSTGRES_PASSWORD@medusa-db:5432/assistant?sslmode=disable
QDRANT_URL=
QDRANT_API_KEY=
LLM_PROVIDER=none
OPENAI_API_KEY=
# Optional OpenAI-compatible /v1 endpoint override.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
POLZA_API_KEY=
NEXT_PUBLIC_AI_ASSISTANT_WIDGET_ENABLED=false
NEXT_PUBLIC_AI_ASSISTANT_CHAT_ENDPOINT=/store/assistant/chat

# --- CORS ---
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# --- Payload CMS / storefront content layer ---
# payload-cms app uses its own local env file. See payload-cms/.env.example for
# DATABASE_URL, PAYLOAD_SECRET and admin runtime. Keep real secrets out of git.
PAYLOAD_ENABLED=false
PAYLOAD_CMS_URL=http://localhost:3100
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3100
PAYLOAD_CONTENT_PREVIEW_TOKEN=CHANGE_ME_PAYLOAD_CONTENT_PREVIEW_TOKEN
PAYLOAD_PREVIEW_SECRET=CHANGE_ME_PAYLOAD_PREVIEW_SECRET
PAYLOAD_REVALIDATE_SECRET=CHANGE_ME_PAYLOAD_REVALIDATE_SECRET
PAYLOAD_SECRET=CHANGE_ME_PAYLOAD_SECRET
PAYLOAD_DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/payload_cms
STOREFRONT_PREVIEW_URL=http://localhost:8000
STOREFRONT_PREVIEW_LOCALE=ru
STOREFRONT_REVALIDATE_URL=http://localhost:8000/api/content/revalidate
PAYLOAD_CORS=http://localhost:8000
PAYLOAD_CSRF=http://localhost:3100
