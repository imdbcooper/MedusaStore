# Payload CMS local runtime template. Copy to payload-cms/.env or run via scripts/payload-run.sh.
# Values are safe development placeholders; do not commit real production secrets.

PAYLOAD_PORT=3100
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3100
PAYLOAD_CMS_URL=http://localhost:3100

# Use a dedicated Payload database. Create it locally before running migrations/seed if it does not exist.
DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/payload_cms
PAYLOAD_DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/payload_cms

PAYLOAD_SECRET=CHANGE_ME_PAYLOAD_SECRET
PAYLOAD_CONTENT_PREVIEW_TOKEN=CHANGE_ME_PAYLOAD_CONTENT_PREVIEW_TOKEN
PAYLOAD_PREVIEW_SECRET=CHANGE_ME_PAYLOAD_PREVIEW_SECRET
PAYLOAD_REVALIDATE_SECRET=CHANGE_ME_PAYLOAD_REVALIDATE_SECRET

STOREFRONT_PREVIEW_URL=http://localhost:8000
STOREFRONT_PREVIEW_LOCALE=ru
STOREFRONT_REVALIDATE_URL=http://localhost:8000/api/content/revalidate
PAYLOAD_CORS=http://localhost:8000
PAYLOAD_CSRF=http://localhost:3100
