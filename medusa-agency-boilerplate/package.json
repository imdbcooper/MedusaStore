{
  "name": "medusa-agency-boilerplate",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "prepare:checkout-runtime": "medusa exec ./src/scripts/prepare-checkout-runtime.ts",
    "admin:api-key:local": "medusa exec ./src/scripts/create-secret-admin-api-key.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "typecheck": "tsc --noEmit",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@gorgo/medusa-fulfillment-apiship": "0.5.1",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/draft-order": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/notification-local": "2.13.6",
    "@medusajs/ui": "4.1.6",
    "nodemailer": "^8.0.7",
    "scrypt-kdf": "2.0.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2"
}
