# Synced from the root-level orchestration contract.
# Canonical client-init contract entrypoint:
# 1. run `npm run client:init:contract` from repository root
# 2. copy root .env.example -> .env
# 3. run `npm run bootstrap` from repository root
# 4. root bootstrap writes deterministic local values here
#
# Keys intentionally excluded from this backend template (root orchestration / other services only):
#   HOST_UID, HOST_GID, POSTGRES_*, REDIS_PORT, MEDUSA_BACKEND_PORT, MEDUSA_ADMIN_HMR_PORT,
#   STOREFRONT_PORT, PAYLOAD_PORT, PAYLOAD_* (payload-cms service), STOREFRONT_PREVIEW_*,
#   STOREFRONT_REVALIDATE_URL, BACKEND_DATABASE_URL, BACKEND_REDIS_URL, STAGING_*,
#   NEXT_PUBLIC_*, AI_ASSISTANT_API_TOKEN, AI_ASSISTANT_CORS_ORIGINS, AI_ASSISTANT_RETRIEVAL_MODE,
#   ASSISTANT_POSTGRES_URI, LLM_PROVIDER, OPENAI_*, GOOGLE_API_KEY, ANTHROPIC_API_KEY,
#   POLZA_API_KEY, QDRANT_*.
# These live in the root `.env.example` and are consumed by docker-compose, storefront,
# payload-cms, or the ai-assistant service, not by the Medusa backend runtime.
NODE_ENV=development
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_JWT_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET
DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5433/medusa
# Public storefront origin for transactional email links (verification, reset, marketing).
STOREFRONT_URL=http://localhost:8000
NOTIFICATION_EMAIL_PROVIDER=local
NOTIFICATION_EMAIL_FROM=notifications@example.com
# Default country code injected into storefront transactional URLs
# (email verification, password reset, marketing confirmation).
# Falls back to `ru` when this env is unset and the caller omits country_code.
NOTIFICATION_DEFAULT_COUNTRY_CODE=ru
# Optional backend-only UniSender credentials for production email path.
UNISENDER_API_KEY=
UNISENDER_BASE_URL=
# Optional backend-only SMTP transport. Keep provider=local until SMTP secrets/TLS/PTR are ready.
# Example future activation for current mail VPS: provider=smtp, host=smtp.slavx.ru, port=587, from=noreply@notify.slavx.ru.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_REPLY_TO=
# Bootstrap/self-signed only. Do not set false for final production with a trusted cert.
SMTP_TLS_REJECT_UNAUTHORIZED=true
# --- Email brand theming (transactional HTML templates) ---
# All BRAND_* vars are optional; safe defaults are used when empty.
BRAND_NAME=SLAVX Studio
BRAND_LOGO_URL=
BRAND_PRIMARY_COLOR=#111827
BRAND_ACCENT_COLOR=#10b981
BRAND_TEXT_COLOR=#111827
BRAND_BACKGROUND_COLOR=#f9fafb
# Optional legal/contact HTML footer; no <script>/<style>/<iframe>/on*= allowed.
BRAND_FOOTER_HTML=

# --- Email verification (customer signup) ---
# TTL of the issued email verification token in minutes; default 1440 (24h).
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# Optional redirect path override inside the storefront verify link; default /account/verify-email.
EMAIL_VERIFICATION_REDIRECT_PATH=/account/verify-email

# --- Password reset (customer forgot/reset) ---
# TTL of the issued password reset token in minutes; default 60 (shorter than email verification
# because it is security-sensitive).
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Optional redirect path override inside the storefront reset link; default /account/reset-password.
PASSWORD_RESET_REDIRECT_PATH=/account/reset-password
# Minimum password length; absolute floor is 8. Applies to reset and authenticated change.
PASSWORD_MIN_LENGTH=8
# Require at least one letter (true|false); default true.
PASSWORD_REQUIRE_LETTER=true
# Require at least one digit (true|false); default true.
PASSWORD_REQUIRE_DIGIT=true

# --- Marketing (Phase 4 groundwork) ---
# Optional separate marketing sender. Falls back to SMTP_FROM/NOTIFICATION_EMAIL_FROM when empty.
# Groundwork only: production-grade separation requires a dedicated SMTP account on the mail server.
MARKETING_EMAIL_FROM=
MARKETING_EMAIL_FROM_NAME=
MARKETING_EMAIL_REPLY_TO=
# Optional mailto address used in the List-Unsubscribe header for marketing emails.
# Leave empty to emit only the https URL part. When set, the value MUST resolve to a
# real inbox on the outbound mail server, otherwise Gmail/Yahoo may treat the header
# as broken and lower deliverability.
MARKETING_UNSUBSCRIBE_MAILTO=
# TTL for double opt-in confirmation tokens (days). Links are rotated on re-subscribe.
MARKETING_DOUBLE_OPTIN_TOKEN_TTL_DAYS=7
# TTL for unsubscribe tokens (days). Industry convention is long-lived; 365 is the recommended default.
MARKETING_UNSUBSCRIBE_TOKEN_TTL_DAYS=365
# Storefront paths for marketing confirm and unsubscribe landing pages.
MARKETING_UNSUBSCRIBE_REDIRECT_PATH=/unsubscribe
MARKETING_CONFIRMATION_REDIRECT_PATH=/marketing/confirm
# Default country code injected into storefront marketing URLs (`/{code}/...`).
# Customers can override via `customer.metadata.marketing.preferred_country_code`.
MARKETING_DEFAULT_COUNTRY_CODE=ru

# Optional backend-only SMS transport contract.
NOTIFICATION_SMS_PROVIDER=disabled
MTS_EXOLVE_API_KEY=
MTS_EXOLVE_SENDER=
MTS_EXOLVE_BASE_URL=
# Optional backend-only VK Community Messaging transport contract.
NOTIFICATION_VK_PROVIDER=disabled
VK_COMMUNITY_ACCESS_TOKEN=
VK_COMMUNITY_GROUP_ID=
VK_API_VERSION=
# Optional backend-only VK ID identity-linking contract.
VK_ID_ENABLED=false
VK_ID_CLIENT_ID=
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=
VK_ID_SCOPES=
VK_ID_SESSION_SECRET=
VK_ID_STOREFRONT_RETURN_ORIGINS=http://localhost:8000
# Optional local smoke helpers for authenticated admin notification requests
MEDUSA_BACKEND_URL=http://localhost:9000
NOTIFICATION_SMOKE_TO=ops@example.com
NOTIFICATION_SMOKE_SUBJECT=Notification v1 smoke
NOTIFICATION_SMOKE_MESSAGE=Notification v1 smoke trigger completed.
# Set true to validate admin smoke route authentication without creating a notification or sending email.
NOTIFICATION_SMOKE_DRY_RUN=false
# Optional staging-only override when verification must authenticate against an already-seeded non-local backend.
# Set via GitHub Secret NOTIFICATION_SMOKE_ADMIN_SECRET_API_KEY; leave empty locally.
NOTIFICATION_SMOKE_ADMIN_SECRET_API_KEY=
# ApiShip/Gorgo is the default fulfillment contour for fresh stores.
# Configure ApiShip token, sandbox/live mode, sender data, default dimensions,
# and carrier connections in Medusa Admin; do not commit real credentials to templates.
# Checkout may calculate rates and commit the selected ApiShip shipping method, but actual
# external fulfillment/shipment execution is default-off unless this exact opt-in is set to true.
APISHIP_SHIPMENT_EXECUTION_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
# Optional backend-controlled allowlist for storefront checkout return origins. Comma-separated origins only.
YOOKASSA_STOREFRONT_RETURN_ORIGINS=http://localhost:8000
# Public Medusa backend endpoint for YooKassa notifications, for example https://api.example.com/yookassa/webhook
YOOKASSA_WEBHOOK_URL=
# Optional shared secret expected in x-yookassa-webhook-secret, x-yookassa-secret, or Authorization: Bearer <secret>
YOOKASSA_WEBHOOK_SECRET=
# Development/test-only override for controlled local environments when YooKassa cannot send a secret header.
YOOKASSA_ALLOW_UNSIGNED_WEBHOOKS=false


# Optional AI Assistant backend adapter. Server-only; never expose the token to storefront/browser.
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_BASE_URL=http://ai-assistant:8000/api/v1
AI_ASSISTANT_SERVER_TOKEN=CHANGE_ME_AI_ASSISTANT_SERVER_TOKEN
AI_ASSISTANT_TIMEOUT_MS=60000
