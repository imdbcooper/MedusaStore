# ============================================
# MedusaStore staging env contract example
# ============================================
# Copy concepts from this file into the real staging .env on the server.
# Do not commit the real staging .env and do not put secrets in Git.
# Real production environment is not provisioned yet (TBD when real production is provisioned).
# Concrete staging host documented by Docs/production_runbook.md:
#   domain: studio.slavx.ru
#   user: som
#   path: /home/som/MedusaStore
#   repo: imdbcooper/MedusaStore
#   branch: main
#
# GitHub deploy secrets are NOT app env and must stay in GitHub Secrets:
#   DEPLOY_HOST, DEPLOY_USER, DEPLOY_PATH, DEPLOY_SSH_PRIVATE_KEY
# Real secrets and non-secret config values are ONLY sourced from GitHub
# Secrets / GitHub Variables and injected into the remote .env during deploy.
# ============================================

# --- Domain / Caddy ---
DEPLOY_DOMAIN=studio.slavx.ru
ACME_EMAIL=admin@studio.slavx.ru
HTTP_PORT=80
HTTPS_PORT=443

# --- Compose project / staging runtime ---
# NODE_ENV=production is a Node.js technical build mode, unrelated to our staging/production environment naming.
COMPOSE_PROJECT_NAME=medusastore
NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_USER=CHANGE_ME_POSTGRES_USER
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=medusa

# Internal Docker-network DB URLs used by staging containers.
DOCKER_DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_POSTGRES_PASSWORD@medusa-db:5432/medusa?sslmode=disable
DOCKER_PAYLOAD_DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_POSTGRES_PASSWORD@medusa-db:5432/payload_cms?sslmode=disable

# Optional non-Docker app DATABASE_URL mirrors. Keep Docker containers on DOCKER_* URLs.
DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_POSTGRES_PASSWORD@medusa-db:5432/medusa?sslmode=disable
PAYLOAD_DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_POSTGRES_PASSWORD@medusa-db:5432/payload_cms?sslmode=disable

# --- Redis ---
DOCKER_REDIS_URL=redis://medusa-redis:6379
REDIS_URL=redis://medusa-redis:6379

# --- Medusa secrets ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
COOKIE_SECRET=CHANGE_ME_LONG_RANDOM_COOKIE_SECRET

# --- Medusa URLs / CORS ---
# Server-side backend URL precedence in storefront:
#   MEDUSA_BACKEND_URL wins over NEXT_PUBLIC_MEDUSA_BACKEND_URL.
# Use the Docker-network URL for server-side rendering inside the storefront container.
MEDUSA_BACKEND_URL=http://medusa-backend:9000
DOCKER_MEDUSA_BACKEND_URL=http://medusa-backend:9000

# Secret Admin API Key Medusa v2 (sk_* token), used by Payload CMS to call
# the Medusa Admin API server-to-server (`Authorization: Basic base64(sk_xxx:)`).
# Single secret shared across all Payload→Medusa integrations
# (product-reviews moderation now, marketing campaigns later).
MEDUSA_ADMIN_SECRET_API_KEY=CHANGE_ME_SECRET_ADMIN_API_KEY

# Public/browser URL through Caddy.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://studio.slavx.ru
DOCKER_NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://studio.slavx.ru
NEXT_PUBLIC_BASE_URL=https://studio.slavx.ru
DOCKER_NEXT_PUBLIC_BASE_URL=https://studio.slavx.ru
NEXT_PUBLIC_DEFAULT_REGION=ru

STORE_CORS=https://studio.slavx.ru,https://admin.slavx.ru
ADMIN_CORS=https://studio.slavx.ru,https://admin.slavx.ru
AUTH_CORS=https://studio.slavx.ru,https://admin.slavx.ru
STOREFRONT_URL=https://studio.slavx.ru

# --- Email verification (customer signup) ---
# TTL of the issued email verification token in minutes; default 1440 (24h).
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# Optional redirect path override inside the storefront verify link; default /account/verify-email.
EMAIL_VERIFICATION_REDIRECT_PATH=/account/verify-email

# --- Password reset (customer forgot/reset) ---
# TTL of the issued password reset token in minutes; default 60. Kept short because it is
# security-sensitive.
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Optional redirect path override inside the storefront reset link; default /account/reset-password.
PASSWORD_RESET_REDIRECT_PATH=/account/reset-password
# Minimum password length; absolute floor is 8. Applies to reset and authenticated change.
PASSWORD_MIN_LENGTH=8
# Require at least one letter (true|false); default true.
PASSWORD_REQUIRE_LETTER=true
# Require at least one digit (true|false); default true.
PASSWORD_REQUIRE_DIGIT=true

# --- Email brand theming (transactional HTML templates) ---
# All BRAND_* vars are optional; safe defaults are used when empty.
BRAND_NAME=SLAVX Studio
BRAND_LOGO_URL=
BRAND_PRIMARY_COLOR=#111827
BRAND_ACCENT_COLOR=#10b981
BRAND_TEXT_COLOR=#111827
BRAND_BACKGROUND_COLOR=#f9fafb
# Optional legal/contact HTML footer; no <script>/<style>/<iframe>/on*= allowed.
BRAND_FOOTER_HTML=

# Must be a real Medusa publishable key for the staging sales channel/region.
# Do not leave pk_build_placeholder in a real staging .env.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=CHANGE_ME_MEDUSA_PUBLISHABLE_KEY

# --- Payload CMS ---
PAYLOAD_PORT=3100
PAYLOAD_ENABLED=true
PAYLOAD_CMS_URL=http://payload-cms:3100
DOCKER_PAYLOAD_CMS_URL=http://payload-cms:3100
PAYLOAD_PUBLIC_SERVER_URL=https://cms.slavx.ru
PAYLOAD_SECRET=CHANGE_ME_LONG_RANDOM_PAYLOAD_SECRET
PAYLOAD_CONTENT_PREVIEW_TOKEN=CHANGE_ME_OPTIONAL_PREVIEW_TOKEN
PAYLOAD_PREVIEW_SECRET=CHANGE_ME_OPTIONAL_PREVIEW_SECRET
PAYLOAD_REVALIDATE_SECRET=CHANGE_ME_OPTIONAL_REVALIDATE_SECRET
# Storefront on-demand revalidate hook secret (Medusa → Next.js cache tags).
# Pair with the storefront's REVALIDATE_SECRET. See plans/product-reviews-module.md §6.6.
STOREFRONT_REVALIDATE_SECRET=CHANGE_ME_STOREFRONT_REVALIDATE_SECRET
# Storefront-side mirror consumed by `/api/revalidate`; must match STOREFRONT_REVALIDATE_SECRET.
REVALIDATE_SECRET=CHANGE_ME_STOREFRONT_REVALIDATE_SECRET

# --- Product reviews (Phase 1/2 backend module) ---
# Reviews CAPTCHA provider — Phase 3 reservation; Phase 1/2 use rate-limit + honeypot.
# Allowed: none | yandex | hcaptcha. Default: none.
REVIEWS_CAPTCHA_PROVIDER=none
STOREFRONT_PREVIEW_URL=https://studio.slavx.ru
STOREFRONT_PREVIEW_LOCALE=ru
STOREFRONT_REVALIDATE_URL=http://storefront:8000/api/content/revalidate
PAYLOAD_CORS=https://cms.slavx.ru,https://studio.slavx.ru
PAYLOAD_CSRF=https://cms.slavx.ru,https://studio.slavx.ru

# --- Migration / seed toggles ---
# Medusa migrations are controlled by the backend image/entrypoint/runtime.
RUN_MEDUSA_MIGRATIONS=true
# Payload migrations and seed are run as one-off jobs by scripts/github-deploy-staging.sh only when true.
RUN_PAYLOAD_MIGRATIONS=false
RUN_PAYLOAD_SEED=false

# --- Staging smoke overrides ---
# Canonical public checks use storefront, Medusa Admin, and Payload CMS subdomains.
SMOKE_BASE_URL=https://studio.slavx.ru
SMOKE_BACKEND_URL=https://admin.slavx.ru/app
SMOKE_PAYLOAD_URL=https://cms.slavx.ru/api/pages

# --- Notifications: baseline local, real provider opt-in ---
# Keep local until SMTP PTR, trusted TLS certificate, real secrets, and smoke approval are complete.
NOTIFICATION_EMAIL_PROVIDER=local
NOTIFICATION_EMAIL_FROM=notifications@studio.slavx.ru
UNISENDER_API_KEY=
UNISENDER_BASE_URL=
# Optional own SMTP transactional provider. Current planned mail infra: smtp.slavx.ru:587, sender noreply@notify.slavx.ru.
SMTP_HOST=smtp.slavx.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@notify.slavx.ru
SMTP_PASSWORD=
SMTP_FROM=noreply@notify.slavx.ru
SMTP_FROM_NAME=MedusaStore
SMTP_REPLY_TO=
# Bootstrap/self-signed only. Do not set false once a trusted cert is in place.
SMTP_TLS_REJECT_UNAUTHORIZED=true
# --- Marketing (Phase 4 groundwork) ---
# Optional separate marketing sender. Falls back to SMTP_FROM when empty.
# Groundwork only: clean separation of transactional vs marketing senders
# needs a dedicated SMTP account on smtpserv (manual operator task, tracked in
# Docs/env_contract.md).
MARKETING_EMAIL_FROM=news@news.slavx.ru
MARKETING_EMAIL_FROM_NAME=SLAVX News
MARKETING_EMAIL_REPLY_TO=
# Optional mailto address used in the List-Unsubscribe header for marketing emails.
# Leave empty to emit only the https URL part. When set, the value MUST resolve to a
# real inbox on smtpserv, otherwise Gmail/Yahoo may treat the header as broken and
# lower deliverability. Creating this inbox is a manual operator task.
MARKETING_UNSUBSCRIBE_MAILTO=
# TTL for double opt-in confirmation tokens (days).
MARKETING_DOUBLE_OPTIN_TOKEN_TTL_DAYS=7
# TTL for unsubscribe tokens (days). Industry convention is long-lived.
MARKETING_UNSUBSCRIBE_TOKEN_TTL_DAYS=365
# Storefront paths for marketing confirm and unsubscribe landing pages.
MARKETING_UNSUBSCRIBE_REDIRECT_PATH=/unsubscribe
MARKETING_CONFIRMATION_REDIRECT_PATH=/marketing/confirm
# Default country code injected into storefront marketing URLs (`/{code}/...`).
MARKETING_DEFAULT_COUNTRY_CODE=ru
# Default country code injected into storefront transactional URLs
# (email verification, password reset, marketing confirmation). Fallback `ru`.
NOTIFICATION_DEFAULT_COUNTRY_CODE=ru
NOTIFICATION_SMS_PROVIDER=disabled
MTS_EXOLVE_API_KEY=
MTS_EXOLVE_SENDER=
MTS_EXOLVE_BASE_URL=
NOTIFICATION_VK_PROVIDER=disabled
VK_COMMUNITY_ACCESS_TOKEN=
VK_COMMUNITY_GROUP_ID=
VK_API_VERSION=

# --- VK ID optional identity linking ---
VK_ID_ENABLED=false
# Phase 5.1 login flow is gated by VK_ID_LOGIN_ENABLED so the linking surface
# can ship to staging independently. Switch to true on staging only after the
# linked-customer login has been smoke tested.
VK_ID_LOGIN_ENABLED=false
# Phase 5.2: gates the VK ID registration branch. Requires VK_ID_ENABLED and
# VK_ID_LOGIN_ENABLED to also be true. Flip to true only after Phase 5.2
# staging smoke confirms the register-by-email flow is working end-to-end.
VK_ID_REGISTER_ENABLED=false
# Phase 5.3: VK ID email trust policy. `any` keeps MVP behaviour; switch to
# `require_verification` to force a verification email after VK registration,
# or `reject` to disable VK-driven registration entirely. See .env.example
# for the full matrix.
VK_ID_EMAIL_TRUST_POLICY=any
# Phase 5.3: TTL (minutes) for the conflict-flow pending-link token.
VK_ID_PENDING_TOKEN_TTL_MINUTES=10
# DEPRECATED (Phase 5.3): VK_ID_REQUIRE_EMAIL is retired; the runtime ignores
# the value. Use VK_ID_EMAIL_TRUST_POLICY to control whether VK emails skip
# the verification email.
# VK_ID_REQUIRE_EMAIL=true
VK_ID_CLIENT_ID=
# Optional. PKCE-only is supported (leave empty); set when VK confidential
# client mode is required.
VK_ID_CLIENT_SECRET=
# VK redirects users back to this URL. Point VK at the storefront proxy
# (`/api/auth/vk-id/callback`), not the bare Medusa Store API path,
# because Medusa enforces `x-publishable-api-key` on every `/store/*` route
# at the framework level and a browser direct redirect from VK cannot
# attach that header. The storefront proxy adds the key on the server side
# and forwards to the Medusa backend internally. Update the redirect URL
# in the VK admin panel to match.
VK_ID_REDIRECT_URI=https://studio.slavx.ru/api/auth/vk-id/callback
VK_ID_SCOPES="vkid.personal_info phone"
# Phase 5.5: allow VK ID registration without email (placeholder email flow).
VK_ID_ALLOW_NO_EMAIL_REGISTER=true
VK_ID_SESSION_SECRET=
VK_ID_STOREFRONT_RETURN_ORIGINS=https://studio.slavx.ru
# Controls the `Secure` flag on the `_medusa_jwt` cookie minted by the VK ID
# login callback. On staging the callback is https behind Caddy, so the
# default `auto` correctly sets Secure. See .env.example for the full matrix.
VK_ID_COOKIE_SECURE=auto
NEXT_PUBLIC_VK_ID_ENABLED=false

# --- YooKassa optional hosted checkout ---
NEXT_PUBLIC_YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://studio.slavx.ru/ru/checkout
YOOKASSA_STOREFRONT_RETURN_ORIGINS=https://studio.slavx.ru
YOOKASSA_WEBHOOK_URL=https://studio.slavx.ru/yookassa/webhook
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_ALLOW_UNSIGNED_WEBHOOKS=false

# --- ApiShip/Gorgo safety ---
# ApiShip credentials/sender/carrier settings live in Medusa Admin/runtime storage.
# This env only controls live external shipment execution.
APISHIP_SHIPMENT_EXECUTION_ENABLED=false

# --- S3-compatible file storage (product images) ---
# S3-compatible endpoint for file uploads (itecocloud).
# forcePathStyle is enabled in medusa-config for S3-compatible endpoints.
S3_FILE_URL=https://s3.itecocloud.online/CHANGE_ME_S3_BUCKET
S3_ACCESS_KEY_ID=CHANGE_ME_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET_ACCESS_KEY
S3_REGION=us-east-1
S3_BUCKET=CHANGE_ME_S3_BUCKET
S3_ENDPOINT=https://s3.itecocloud.online

# --- AI Assistant optional integration ---
# Safe first step: one assistant replica plus Caddy/API-gateway limits.
# Multi-replica assistant requires Redis-backed or gateway-level distributed rate limiting.
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_BASE_URL=http://ai-assistant:8000/api/v1
AI_ASSISTANT_API_TOKEN=CHANGE_ME_STRONG_AI_ASSISTANT_API_TOKEN
AI_ASSISTANT_SERVER_TOKEN=CHANGE_ME_STRONG_AI_ASSISTANT_SERVER_TOKEN
AI_ASSISTANT_TIMEOUT_MS=60000
AI_ASSISTANT_CORS_ORIGINS=https://studio.slavx.ru
AI_ASSISTANT_RETRIEVAL_MODE=markdown
ASSISTANT_POSTGRES_URI=postgresql://assistant:CHANGE_ME_ASSISTANT_POSTGRES_PASSWORD@medusa-db:5432/assistant?sslmode=disable
QDRANT_URL=
QDRANT_API_KEY=
LLM_PROVIDER=none
OPENAI_API_KEY=
# Optional OpenAI-compatible /v1 endpoint override.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
POLZA_API_KEY=
NEXT_PUBLIC_AI_ASSISTANT_WIDGET_ENABLED=false
NEXT_PUBLIC_AI_ASSISTANT_CHAT_ENDPOINT=/store/assistant/chat

# --- Optional storefront public/runtime flags ---
NEXT_PUBLIC_STOREFRONT_PRESET=atelier
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# --- Optional operational smoke helpers ---
NOTIFICATION_SMOKE_TO=ops@example.com
NOTIFICATION_SMOKE_SUBJECT=Production notification smoke
NOTIFICATION_SMOKE_MESSAGE=Production notification smoke trigger completed.
NOTIFICATION_SMOKE_ADMIN_SECRET_API_KEY=
BACKEND_DATABASE_URL=
BACKEND_REDIS_URL=
STAGING_VERIFICATION_CONTOUR=smoke:backend,smoke:storefront,smoke:browser,smoke:notification
STAGING_BROWSER_ACCOUNT_PATH=/ru/account
