# Root-level canonical defaults for local development.
# Run `npm run bootstrap` from repository root to sync this file and replace the placeholder publishable key.
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_BACKEND_PORT=9000

# This placeholder is intentionally invalid until root bootstrap writes the real key from backend seed output.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=REPLACE_WITH_ROOT_BOOTSTRAP

# Storefront runtime baseline.
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=ru

# YooKassa is the primary hosted checkout path but remains opt-in on the storefront.
NEXT_PUBLIC_YOOKASSA_ENABLED=false

# Stripe-compatible variables are optional and only used when a compatible provider is enabled.
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

REVALIDATE_SECRET=supersecret
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
