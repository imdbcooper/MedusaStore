# AI Assistant backend
AI_ASSISTANT_ENV=development
AI_ASSISTANT_HOST=0.0.0.0
AI_ASSISTANT_PORT=8000
AI_ASSISTANT_PUBLIC_BASE_URL=http://localhost:8000/api/v1
# Required for protected ingestion/admin endpoints. Send as Authorization: Bearer <token> or X-API-Key.
AI_ASSISTANT_API_TOKEN=change-me
AI_ASSISTANT_CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Runtime mode: markdown | vector | lightrag | auto
AI_ASSISTANT_RETRIEVAL_MODE=markdown

# PostgreSQL
ASSISTANT_POSTGRES_URI=postgresql://assistant:assistant@localhost:5432/assistant

# Qdrant optional vector mode
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=assistant

# Neo4j optional LightRAG mode
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# LLM provider: openai | google | anthropic | polza | local
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
POLZA_API_KEY=
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=openai/gpt-4o-mini
POLZA_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
POLZA_EMBEDDING_DIM=4096

# Medusa integration
# Used by product ingestion and Phase 3 live commerce tools to read Store API products/carts.
# Store API calls use the publishable key only; admin token is not sent to /store/* endpoints.
# Chat may show price/availability only after live Store API checks succeed.
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_API_TOKEN=
MEDUSA_STORE_PUBLISHABLE_KEY=
MEDUSA_DEFAULT_REGION_ID=
MEDUSA_DEFAULT_SALES_CHANNEL_ID=
MEDUSA_PRODUCTS_PAGE_LIMIT=100
MEDUSA_REQUEST_TIMEOUT_SECONDS=15
MEDUSA_PRODUCTS_FIELDS=id,handle,title,subtitle,description,thumbnail,+metadata,+tags,collection.id,collection.title,categories.id,categories.name,categories.handle,options.id,options.title,options.values.value,variants.id,variants.title,variants.sku,variants.options.value,*variants.calculated_price,+variants.inventory_quantity,images.url,updated_at

# Payload CMS integration
PAYLOAD_CMS_URL=http://localhost:3001
PAYLOAD_API_TOKEN=

# Chat/session
CHAT_HISTORY_LIMIT=10
CHAT_MAX_INPUT_CHARS=4000
CHAT_RATE_LIMIT=60/minute

# Knowledge
KNOWLEDGE_DIR=./knowledge
MARKDOWN_FRONTMATTER_REQUIRED=false

# Safety/observability
ENABLE_TOOL_AUDIT=true
ENABLE_FEEDBACK=true
ENABLE_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=medusa-ai-assistant
